@model IEnumerable<FilmDunyasi.Models.Movie>
@{
    ViewData["Title"] = "Oyun Portalı";
    var liste = Model ?? new List<FilmDunyasi.Models.Movie>();
    
    // İstatistikler (Filtreleme yapsan da tüm listeden sayar)
    int toplam = liste.Count();
    int pcAdet = liste.Count(x => (x.Platform ?? "").Contains("PC"));
    int konsolAdet = liste.Count(x => (x.Platform ?? "").Contains("Konsol"));
    int mobilAdet = liste.Count(x => (x.Platform ?? "").Contains("Mobil"));
}

<div class="container-fluid px-3 text-center">
    <div class="row mb-5 justify-content-center">
        <div class="col-md-8">
            <div class="d-flex flex-wrap justify-content-center gap-2 mb-4">
                <a href="/Movies" class="btn btn-sm btn-outline-info rounded-pill px-4 fw-bold">TÜMÜ</a>
                <a href="/Movies?searchString=PC" class="btn btn-sm btn-outline-secondary rounded-pill px-3">PC</a>
                <a href="/Movies?searchString=Konsol" class="btn btn-sm btn-outline-secondary rounded-pill px-3">KONSOL</a>
                <a href="/Movies?searchString=Mobil" class="btn btn-sm btn-outline-secondary rounded-pill px-3">MOBİL</a>
            </div>
            <form method="get" action="/Movies" class="d-flex position-relative shadow-lg">
                <input name="searchString" class="form-control bg-dark text-white border-info rounded-pill ps-4 shadow-none" 
                       placeholder="Oyun veya platform ara..." value="@Context.Request.Query["searchString"]"
                       style="height:50px; border-width:2px; background:rgba(0,0,0,0.4) !important;">
                <button class="btn rounded-pill position-absolute end-0 h-100 px-4 fw-bold" type="submit" 
                        style="background:var(--main); color:#000; border:none; z-index:10;">ARA</button>
            </form>
        </div>
    </div>

    <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-5 g-4">
        @foreach (var item in liste) 
        {
            <div class="col">
                <div class="card h-100 border-0 rounded-4 glow-card overflow-hidden" style="background:var(--card) !important; position:relative;">
                    <a href="/Movies/Edit/@item.Id" class="position-absolute top-0 end-0 m-2 text-warning" style="z-index:5;"><i class="fas fa-edit shadow-sm"></i></a>
                    <div class="position-relative">
                        <img src="@item.ImageUrl" class="card-img-top" style="height:170px; object-fit:cover;">
                        <span class="badge position-absolute bottom-0 start-0 m-2 bg-dark bg-opacity-75 text-info border border-info" style="font-size:0.7rem;">@item.Genre</span>
                    </div>
                    <div class="card-body p-3">
                        <h6 class="fw-bold mb-3 text-truncate" style="color:var(--text);">@item.Title</h6>
                        <button class="btn btn-outline-info btn-sm rounded-pill w-100 fw-bold py-2 shadow-none" data-bs-toggle="modal" data-bs-target="#m-@item.Id">DETAYLAR</button>
                    </div>
                </div>
            </div>

            <div class="modal fade" id="m-@item.Id" tabindex="-1" aria-hidden="true" style="background: rgba(0,0,0,0.9) !important;">
                <div class="modal-dialog" style="position: fixed !important; top: 50% !important; left: 50% !important; transform: translate(-50%, -50%) !important; width: 950px !important; max-width: 95% !important; margin: 0 !important; border: none !important; z-index: 9999 !important;">
                    <div class="modal-content overflow-hidden border-0 shadow-lg">
                        <div class="row g-0 text-start">
                            <div class="col-md-5 d-none d-md-block">
                                <img src="@item.ImageUrl" class="w-100 h-100" style="object-fit:cover; min-height:500px;">
                            </div>
                            <div class="col-md-7 p-4 p-lg-5 d-flex flex-column justify-content-center text-center">
                                <h1 class="fw-bold mb-2" style="font-family:'Orbitron'; color: var(--main); text-shadow: 0 0 15px var(--main);">@item.Title</h1>
                                <div class="mb-4 d-flex justify-content-center gap-2">
                                    <span class="badge border border-info text-info px-3 py-2 rounded-pill">@item.Platform</span>
                                    <span class="badge bg-dark border border-warning text-warning px-3 py-2 rounded-pill">@item.Genre</span>
                                    <span class="badge bg-secondary px-3 py-2 rounded-pill">@item.Year</span>
                                </div>
                                <hr style="border-color: var(--main); opacity: 0.2; width: 60%; margin: 10px auto 25px auto;">
                                <div style="max-height: 200px; overflow-y: auto; padding: 0 15px;">
                                    <h6 class="text-warning fw-bold small text-uppercase mb-2">Hakkında</h6>
                                    <p class="small opacity-75 mb-3" style="line-height: 1.8;">@(item.Description ?? "Açıklama yok.")</p>
                                    <h6 class="text-warning fw-bold small text-uppercase mb-2">Nasıl Oynanır?</h6>
                                    <p class="small opacity-75 mb-4">@(item.HowToPlay ?? "Bilgi yok.")</p>
                                </div>
                                <div class="d-flex gap-2 mt-4">
                                    <a href="/Movies/Edit/@item.Id" class="btn btn-outline-warning btn-sm rounded-pill flex-grow-1 fw-bold">DÜZENLE</a>
                                    <button class="btn btn-outline-light btn-sm rounded-pill px-5 fw-bold shadow-none" data-bs-dismiss="modal">KAPAT</button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    <div class="row mt-5 pt-5 justify-content-center pb-5">
        <div class="col-12"><hr class="border-secondary opacity-10 mb-5"></div>
        <div class="col-md-2 col-6">
            <div class="p-3 rounded-4 bg-dark bg-opacity-25 border border-secondary border-opacity-10 mb-3 shadow-sm">
                <h2 class="fw-bold mb-0" style="color:var(--main); text-shadow: 0 0 10px var(--main);">@toplam</h2>
                <small class="opacity-50 fw-bold">TOPLAM</small>
            </div>
        </div>
        <div class="col-md-2 col-6">
            <div class="p-3 rounded-4 bg-dark bg-opacity-25 border border-secondary border-opacity-10 mb-3 shadow-sm">
                <h2 class="fw-bold mb-0" style="color:var(--main);">@pcAdet</h2>
                <small class="opacity-50 fw-bold">PC</small>
            </div>
        </div>
        <div class="col-md-2 col-6">
            <div class="p-3 rounded-4 bg-dark bg-opacity-25 border border-secondary border-opacity-10 mb-3 shadow-sm">
                <h2 class="fw-bold mb-0" style="color:var(--main);">@konsolAdet</h2>
                <small class="opacity-50 fw-bold">KONSOL</small>
            </div>
        </div>
        <div class="col-md-2 col-6">
            <div class="p-3 rounded-4 bg-dark bg-opacity-25 border border-secondary border-opacity-10 mb-3 shadow-sm">
                <h2 class="fw-bold mb-0" style="color:var(--main);">@mobilAdet</h2>
                <small class="opacity-50 fw-bold">MOBİL</small>
            </div>
        </div>
    </div>
</div>

<style>
    @@media (min-width: 1200px) { .row-cols-lg-5 > * { flex: 0 0 20%; max-width: 20%; } }
    .glow-card:hover { transform: translateY(-8px); box-shadow: 0 0 15px var(--main); }
    ::-webkit-scrollbar { width: 5px; }
    ::-webkit-scrollbar-thumb { background: var(--main); border-radius: 10px; }
</style>