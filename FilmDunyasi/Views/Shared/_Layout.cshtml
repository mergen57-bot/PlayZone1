<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>PlayZone - Cyber Dashboard</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@500;700&family=Rajdhani:wght@600;700&display=swap" rel="stylesheet">
    <style>
        :root { --main: #0dcaf0; --bg: #050505; --card: #111115; --text: #eee; }
        body.theme-red { --main: #ff4d4d; --bg: #0d0000; }
        body.theme-green { --main: #00ff41; --bg: #000800; }
        body.theme-purple { --main: #bc13fe; --bg: #0a0012; }
        body.theme-white { --main: #0062ff; --bg: #f8f9fa; --card: #fff; --text: #111; }
        body { background: var(--bg); color: var(--text); font-family: 'Rajdhani', sans-serif; transition: 0.4s; overflow-x: hidden; min-height: 100vh; }
        #bg-canvas { position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: -1; opacity: 0.15; pointer-events: none; }
        .modal { text-align: center !important; padding: 0 !important; background: rgba(0,0,0,0.85) !important; }
        .modal:before { content: ''; display: inline-block; height: 100%; vertical-align: middle; margin-right: -4px; }
        .modal-dialog { display: inline-block !important; text-align: left; vertical-align: middle; width: 950px !important; max-width: 95% !important; margin: 0 !important; border: none !important; }
        .modal-content { background: var(--card) !important; color: var(--text) !important; border: 2px solid var(--main) !important; border-radius: 20px !important; box-shadow: 0 0 30px var(--main); }
        .navbar { background: rgba(0,0,0,0.9) !important; border-bottom: 2px solid var(--main); }
        .clock-time { color: var(--main); font-family: 'Orbitron'; font-weight: 700; text-shadow: 0 0 10px var(--main); font-size: 1.3rem; }
        .color-dot { width: 22px; height: 22px; border-radius: 50%; cursor: pointer; border: 2px solid #fff; }
    </style>
</head>
<body class="theme-blue">
    <canvas id="bg-canvas"></canvas>
    <nav class="navbar navbar-expand-lg navbar-dark sticky-top">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/Movies" style="font-family:'Orbitron'; color:var(--main);">PLAYZONE</a>
            <div class="ms-auto d-flex align-items-center gap-4">
                <div class="d-flex gap-2 p-2 bg-dark bg-opacity-50 rounded-pill border border-secondary border-opacity-25">
                    <div class="color-dot" style="background:#0dcaf0" onclick="setTheme('blue')"></div>
                    <div class="color-dot" style="background:#ff4d4d" onclick="setTheme('red')"></div>
                    <div class="color-dot" style="background:#00ff41" onclick="setTheme('green')"></div>
                    <div class="color-dot" style="background:#bc13fe" onclick="setTheme('purple')"></div>
                    <div class="color-dot" style="background:#ffffff; border-color:#000" onclick="setTheme('white')"></div>
                </div>
                <div class="text-end border-start border-secondary ps-3">
                    <div id="txtTime" class="clock-time">00:00:00</div>
                </div>
            </div>
        </div>
    </nav>

    @if (Context.Request.Query.ContainsKey("searchString") || ViewContext.RouteData.Values["action"]?.ToString() != "Index")
    {
        <div class="container mt-4">
            <div class="d-flex gap-2">
                <a href="javascript:history.back()" class="btn btn-outline-secondary btn-sm rounded-pill px-3 fw-bold shadow-none">
                    <i class="fas fa-arrow-left me-1"></i> GERİ
                </a>
                <a href="/Movies" class="btn btn-outline-info btn-sm rounded-pill px-3 fw-bold shadow-none">
                    <i class="fas fa-home me-1"></i> ANA MENÜ
                </a>
            </div>
        </div>
    }

    <div class="container mt-5">@RenderBody()</div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function setTheme(color) { document.body.className = 'theme-' + color; localStorage.setItem('pref-theme', color); }
        const saved = localStorage.getItem('pref-theme'); if(saved) setTheme(saved);
        setInterval(() => { document.getElementById('txtTime').innerText = new Date().toLocaleTimeString('tr-TR'); }, 1000);
        const canvas = document.getElementById('bg-canvas'); const ctx = canvas.getContext('2d');
        canvas.width = window.innerWidth; canvas.height = window.innerHeight;
        const d = Array(Math.floor(canvas.width/20)).fill(1);
        function draw() { ctx.fillStyle = 'rgba(0,0,0,0.05)'; ctx.fillRect(0,0,canvas.width,canvas.height); ctx.fillStyle = '#444'; ctx.font = '15px arial';
            d.forEach((y, i) => { ctx.fillText(String.fromCharCode(Math.random()*128), i*20, y*20); if(y*20 > canvas.height && Math.random() > 0.975) d[i]=0; d[i]++; });
        } setInterval(draw, 33);
    </script>
</body>
</html>