@model FilmDunyasi.Models.Movie
<div class="container mt-4 text-white">
    <div class="row glass-card p-4 rounded-4 border-info">
        <div class="col-md-4">
            <img src="@Model.ImageUrl" class="img-fluid rounded shadow-lg" />
        </div>
        <div class="col-md-8">
            <h1 class="text-cyan">@Model.Title</h1>
            <hr class="border-secondary">
            <h3>Yıl: <span class="text-info">@Model.Year</span></h3>
            <h3>Tür: <span class="text-info">@(Model.Genre ?? "Belirtilmemiş")</span></h3>
            <div class="mt-5">
                <a href="/Movies/Edit/@Model.Id" class="btn btn-warning px-4">Düzenle</a>
                <a href="/Movies" class="btn btn-outline-light px-4">Listeye Dön</a>
            </div>
        </div>
    </div>
</div>