@model IEnumerable<FilmDunyasi.Models.Movie>
@{
    var liste = Model ?? new List<FilmDunyasi.Models.Movie>();
    int tC = liste.Count();
    int pC = liste.Count(x => (x.Platform ?? "").Contains("PC"));
    int mC = liste.Count(x => (x.Platform ?? "").Contains("Mobil"));
    int kC = liste.Count(x => (x.Platform ?? "").Contains("Konsol"));
}

<div class="container-fluid px-4 pb-5">
    <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-5 g-4 mt-2">
        @foreach (var item in liste) {
            <div class="col">
                <div class="card h-100 bg-custom-card border-custom rounded-4 overflow-hidden glow-effect shadow-sm">
                    <img src="@item.ImageUrl" class="card-img-top" style="height:160px; object-fit:cover;">
                    <div class="card-body p-3 text-center">
                        <h6 class="fw-bold mb-3 text-truncate" style="color:var(--text);">@item.Title</h6>
                        
                        <button type="button" class="btn btn-theme-solid btn-sm rounded-pill w-100 fw-bold py-2 shadow-none" 
                                data-bs-toggle="modal" data-bs-target="#m-@item.Id">
                            <i class="fas fa-rocket me-1"></i> DETAYLAR
                        </button>
                    </div>
                </div>
            </div>

            <div class="modal fade" id="m-@item.Id" tabindex="-1" aria-hidden="true">
                <div class="modal-dialog modal-dialog-centered modal-lg">
                    <div class="modal-content border-0 rounded-4 overflow-hidden shadow-lg" style="background: var(--card); color: var(--text); border: 2px solid var(--main) !important;">
                        <div class="row g-0">
                            <div class="col-md-5">
                                <img src="@item.ImageUrl" class="h-100 w-100" style="object-fit: cover; min-height: 300px;">
                            </div>
                            <div class="col-md-7 p-4">
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <h3 class="fw-bold text-theme mb-0">@item.Title</h3>
                                    <span class="badge bg-dark border border-theme text-theme">@item.Year</span>
                                </div>
                                <p class="text-info small mb-3">@item.Platform | @item.Genre</p>
                                
                                <h6 class="text-warning fw-bold small text-uppercase mb-1">Özet</h6>
                                <p class="small opacity-75 mb-3" style="max-height: 100px; overflow-y: auto;">@(item.Description ?? "Bilgi yok.")</p>
                                
                                <h6 class="text-warning fw-bold small text-uppercase mb-1">Nasıl Oynanır?</h6>
                                <p class="small opacity-75 mb-4">@(item.HowToPlay ?? "Bilgi yok.")</p>
                                
                                <div class="d-flex gap-2">
                                    <a href="/Movies/Edit/@item.Id" class="btn btn-outline-warning btn-sm rounded-pill flex-grow-1">DÜZENLE</a>
                                    <button type="button" class="btn btn-outline-secondary btn-sm rounded-pill px-4" data-bs-dismiss="modal">KAPAT</button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    <div class="row mt-5 pt-5 text-center">
        <div class="col-12"><hr style="border-color:rgba(255,255,255,0.1);" class="mb-5"></div>
        <div class="col-md-3 col-6"><div class="stat-box"><h3 class="text-theme">@tC</h3><small>TOPLAM</small></div></div>
        <div class="col-md-3 col-6"><div class="stat-box"><h3 class="text-theme">@pC</h3><small>PC</small></div></div>
        <div class="col-md-3 col-6"><div class="stat-box"><h3 class="text-theme">@kC</h3><small>KONSOL</small></div></div>
        <div class="col-md-3 col-6"><div class="stat-box"><h3 class="text-theme">@mC</h3><small>MOBİL</small></div></div>
    </div>
</div>

<style>
    @@media (min-width: 1200px) { .row-cols-lg-5 > * { flex: 0 0 20%; max-width: 20%; } }
    .bg-custom-card { background: var(--card) !important; }
    .border-custom { border: 1px solid rgba(255,255,255,0.1) !important; }
    .btn-theme-solid { background: var(--main); color: #fff; border: none; transition: 0.3s; }
    .btn-theme-solid:hover { background: #fff; color: #000; box-shadow: 0 0 15px var(--main); }
    .stat-box { padding: 20px; border: 1px solid rgba(255,255,255,0.1); border-radius: 15px; background: var(--card); }
    .glow-effect:hover { border-color: var(--main) !important; transform: translateY(-5px); }
</style>