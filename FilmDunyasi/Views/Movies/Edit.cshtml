@model FilmDunyasi.Models.Movie

@{
    ViewData["Title"] = "Oyunu Düzenle - PlayZone";
}

<div class="container mt-5 mb-5">
    <div class="card bg-dark border-warning shadow-lg rounded-4 p-4 text-white" 
         style="border-width: 2px; background: linear-gradient(145deg, #050505, #151510); box-shadow: 0 0 20px rgba(255, 193, 7, 0.1) !important;">
        
        <h2 class="text-warning fw-bold mb-4 text-center" style="font-family: 'Orbitron', sans-serif; letter-spacing: 2px;">
            <i class="fas fa-edit me-2"></i> OYUNU GÜNCELLE
        </h2>

        <form asp-action="Edit" enctype="multipart/form-data" method="post">
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="ImageUrl" />

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label text-warning fw-bold small text-uppercase">Oyun Adı</label>
                    <input asp-for="Title" class="form-control bg-black text-white border-secondary shadow-none focus-warning" required />
                </div>

                <div class="col-md-6 mb-3">
                    <label class="form-label text-warning fw-bold small text-uppercase">Çıkış Yılı</label>
                    <input asp-for="Year" type="number" class="form-control bg-black text-white border-secondary shadow-none focus-warning" required />
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label text-info fw-bold small text-uppercase">Platformlar (Mevcut: @Model.Platform)</label>
                    <select name="selectedPlatforms" class="form-select bg-black text-white border-secondary shadow-none focus-info" multiple style="height: 100px;">
                        <option value="PC">🖥️ PC</option>
                        <option value="Konsol">🎮 Konsol</option>
                        <option value="Mobil">📱 Mobil</option>
                    </select>
                    <div class="form-text text-white-50 small">Yeni seçimler eskisinin üzerine yazılır. (Ctrl + Tık)</div>
                </div>

                <div class="col-md-6 mb-3">
                    <label class="form-label text-info fw-bold small text-uppercase">Oyun Türleri (Mevcut: @Model.Genre)</label>
                    <select name="selectedGenres" class="form-select bg-black text-white border-secondary shadow-none focus-info" multiple style="height: 100px;">
                        <option value="Aksiyon">🔫 Aksiyon</option>
                        <option value="Macera">🗺️ Macera</option>
                        <option value="Spor">⚽ Spor</option>
                        <option value="Strateji">🧠 Strateji</option>
                        <option value="RPG">🎭 RPG</option>
                        <option value="Korku">😱 Korku</option>
                        <option value="Bulmaca">🧩 Bulmaca</option>
                        <option value="Sosyal Oyun">🤝 Sosyal Oyun</option>
                        <option value="Simülasyon">🏠 Simülasyon</option>
                        <option value="Yarış">🚗 Yarış</option>
                        <option value="Açık Dünya">🌍 Açık Dünya</option>
                        <option value="FPS">🎯 FPS</option>
                        <option value="Hayatta Kalma">🏕️ Hayatta Kalma</option>
                    </select>
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label text-white-50 fw-bold small text-uppercase">Oyun Açıklaması</label>
                <textarea asp-for="Description" class="form-control bg-black text-white border-secondary shadow-none focus-warning" rows="3"></textarea>
            </div>

            <div class="mb-3">
                <label class="form-label text-white-50 fw-bold small text-uppercase">Nasıl Oynanır? / Kontroller</label>
                <textarea asp-for="HowToPlay" class="form-control bg-black text-white border-secondary shadow-none focus-warning" rows="3"></textarea>
            </div>

            <div class="mb-4 text-center p-3 border border-secondary border-dashed rounded-3">
                <label class="form-label text-warning fw-bold small d-block mb-3">KAPAK RESMİNİ DEĞİŞTİR</label>
                <div class="d-flex align-items-center justify-content-center gap-4 flex-wrap">
                    <div class="text-center">
                        <p class="small text-white-50 mb-1">Şu anki:</p>
                        <img src="@Model.ImageUrl" class="rounded shadow-sm border border-secondary" style="height: 80px; width: 120px; object-fit: cover;">
                    </div>
                    <div class="flex-grow-1">
                        <input asp-for="ImageFile" type="file" class="form-control bg-black text-white border-warning shadow-none" accept="image/*" />
                    </div>
                </div>
            </div>

            <div class="d-flex gap-3">
                <a href="/Movies" class="btn btn-outline-secondary w-50 rounded-pill fw-bold py-2">
                    <i class="fas fa-times me-2"></i> İPTAL
                </a>
                <button type="submit" class="btn btn-warning w-50 rounded-pill fw-bold text-dark py-2 shadow-gold">
                    <i class="fas fa-sync-alt me-2"></i> DEĞİŞİKLİKLERİ KAYDET
                </button>
            </div>
        </form>
    </div>
</div>

<style>
    /* Fokus Renkleri */
    .focus-warning:focus { border-color: #ffc107 !important; box-shadow: 0 0 15px rgba(255, 193, 7, 0.2) !important; }
    .focus-info:focus { border-color: #0dcaf0 !important; box-shadow: 0 0 15px rgba(13, 202, 240, 0.2) !important; }
    
    /* Neon Altın Buton */
    .shadow-gold:hover { 
        box-shadow: 0 0 25px rgba(255, 193, 7, 0.5); 
        transform: translateY(-2px);
        transition: 0.3s;
    }

    /* Inputların genel stili */
    .form-control, .form-select {
        border-radius: 10px;
        transition: 0.3s;
    }
</style>